---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { SITE } from '../../lib/constants';
import { getCollection } from 'astro:content';
import Search from 'astro-pagefind/components/Search';
import { GridScan } from '../../components/ui/GridScan';
import GradientText from '../../components/ui/GradientText';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const postsWithMetadata = await Promise.all(
  posts.map(async (post) => {
    const wordCount = post.body ? post.body.trim().split(/\s+/).length : 0;
    const readingTime = Math.max(1, Math.ceil(wordCount / 200));
    return { ...post, readingTime };
  })
);

const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
---

<BaseLayout
  title={`Blog - ${SITE.title}`}
  description="All blog posts about web development, side projects, and building in public."
>
  <div class="fixed inset-0 -z-10 pointer-events-none opacity-15 dark:opacity-35 transition-opacity duration-500">
    <GridScan
      client:load
      sensitivity={0.55}
      lineThickness={1}
      linesColor="#0e4f5c"
      gridScale={0.1}
      scanColor="#22d3ee"
      scanOpacity={0.35}
      enablePost
      bloomIntensity={0.5}
      chromaticAberration={0.002}
      noiseIntensity={0.01}
    />
  </div>

  <section class="mx-auto max-w-6xl px-6 py-12 relative z-10">

    <div class="text-center mb-16">
      <span class="inline-block font-mono text-[10px] tracking-[0.3em]
        text-cyan-600 dark:text-cyan-500
        border border-cyan-500/40 dark:border-cyan-500/30
        bg-cyan-500/10 dark:bg-cyan-500/10
        rounded-full px-4 py-1 uppercase mb-6">
        System_Active: Directory_Root
      </span>

      <div class="mt-2">
        <GradientText
          client:load
          colors={["#22d3ee", "#06b6d4", "#0e7490", "#22d3ee"]}
          animationSpeed={8}
          showBorder={false}
          className="text-7xl md:text-8xl font-black tracking-tighter uppercase italic
            drop-shadow-[0_0_30px_rgba(34,211,238,0.25)] dark:drop-shadow-[0_0_30px_rgba(34,211,238,0.4)]"
        >
          Blogs
        </GradientText>
      </div>
    </div>

    <div class="max-w-2xl mx-auto mb-20 relative">
      <div class="relative group rounded-xl
        bg-white/80 dark:bg-slate-900
        border border-cyan-500/20 dark:border-cyan-500/20
        shadow-[0_0_30px_rgba(34,211,238,0.04)] dark:shadow-[0_0_30px_rgba(34,211,238,0.05)]
        overflow-hidden backdrop-blur-sm">
        <span class="absolute left-4 top-1/2 -translate-y-1/2 font-mono text-cyan-600 dark:text-cyan-500 z-10 select-none">$</span>
          <Search id="search" className="pagefind-ui" uiOptions={{ showImages: false }} />
        </div>
      </div>
    </div>

    <div class="grid lg:grid-cols-12 gap-8">

      <div class="lg:col-span-8 space-y-8">

        {postsWithMetadata.slice(0, 1).map(post => (
          <a
            href={`/blog/${post.id}`}
            class="glass-card overflow-hidden group block
              hover:border-cyan-500/30 dark:hover:border-cyan-500/30
              transition-colors duration-300"
          >
            <div class="flex flex-col md:flex-row h-full">
              <!-- Image half -->
              <div class="md:w-1/2 aspect-square md:aspect-auto overflow-hidden
                bg-gray-100 dark:bg-slate-800">
                {post.data.heroImage ? (
                  <img
                    src={post.data.heroImage}
                    alt={post.data.title}
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105
                      opacity-90 dark:opacity-80 dark:mix-blend-luminosity"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-linear-to-br from-cyan-500/10 to-slate-800">
                    <svg class="h-16 w-16 text-cyan-500/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                    </svg>
                  </div>
                )}
              </div>

              <!-- Content half -->
              <div class="p-8 flex flex-col justify-center md:w-1/2
                bg-white/60 dark:bg-slate-900/60 backdrop-blur-sm">
                <div class="flex items-center justify-between mb-4">
                  <span class="bg-cyan-500/10 dark:bg-[#293250] text-cyan-700 dark:text-[#8ea4ff]
                    font-mono text-[9px] px-2 py-0.5 rounded uppercase tracking-widest border border-cyan-500/20 dark:border-transparent">
                    {post.data.tags[0] || 'General'}
                  </span>
                  <span class="font-mono text-[9px] text-gray-400 dark:text-slate-500 uppercase tracking-widest">
                    {new Date(post.data.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </span>
                </div>

                <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-4
                  group-hover:text-cyan-600 dark:group-hover:text-cyan-400 transition-colors leading-tight">
                  {post.data.title}
                </h2>

                <p class="text-gray-500 dark:text-slate-400 text-sm leading-relaxed line-clamp-3 mb-8">
                  {post.data.description}
                </p>

                <div class="mt-auto flex items-center justify-between">
                  <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded-full bg-cyan-900 border border-cyan-500/50 flex items-center justify-center overflow-hidden shrink-0">
                      <img src="/avatar.png" alt="Arjun Nambiar" class="w-full h-full object-cover" onerror="this.style.display='none'" />
                    </div>
                    <span class="font-mono tracking-widest text-[9px] text-gray-600 dark:text-slate-300 uppercase">
                      Arjun_Nambiar
                    </span>
                  </div>
                  <span class="font-mono text-[9px] text-gray-400 dark:text-slate-500 uppercase tracking-widest">
                    {post.readingTime} min read
                  </span>
                </div>
              </div>
            </div>
          </a>
        ))}

        <div class="grid md:grid-cols-2 gap-6">
          {postsWithMetadata.slice(1).map((post) => (
            <BlogCard post={post} readingTime={post.readingTime} />
          ))}
        </div>

        {postsWithMetadata.length === 0 && (
          <div class="rounded-2xl border border-dashed border-gray-200 dark:border-white/10 py-20 text-center">
            <p class="text-gray-400 dark:text-slate-500 font-mono text-sm">No posts found in system.</p>
          </div>
        )}
      </div>

      <aside class="lg:col-span-4 space-y-6">

        <div class="glass-card p-6
          bg-white/70 dark:bg-slate-900/80
          backdrop-blur-sm">
          <h3 class="font-mono text-xs uppercase text-cyan-600 dark:text-cyan-500 mb-6 flex items-center gap-2">
            <div class="w-1.5 h-3 bg-cyan-500 rounded-sm"></div>
            Trending_Topics
          </h3>
          {allTags.length > 0 ? (
            <ul class="space-y-4 font-mono text-[10px] uppercase tracking-widest">
              {allTags.slice(0, 5).map((tag, i) => (
                <li>
                  <a
                    href={`/blog/tag/${tag}`}
                    class="flex items-center group text-gray-500 dark:text-slate-400
                      hover:text-cyan-600 dark:hover:text-cyan-400 transition-colors"
                  >
                    <span class="text-gray-300 dark:text-slate-600 mr-2 group-hover:text-cyan-500 dark:group-hover:text-cyan-600 transition-colors">
                      #{String(i + 1).padStart(2, '0')}_
                    </span>
                    {tag.replace(/\s+/g, '_')}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="font-mono text-[10px] text-gray-400 dark:text-slate-600 uppercase tracking-widest">No tags yet.</p>
          )}
        </div>

        <div class="glass-card p-8 text-center relative overflow-hidden group
          bg-cyan-50/80 dark:bg-cyan-950/20
          border-cyan-200/60 dark:border-cyan-500/20">
          <div class="absolute inset-0
            bg-cyan-500/5 dark:bg-cyan-500/5
            translate-y-full group-hover:translate-y-0
            transition-transform duration-500 pointer-events-none">
          </div>

          <div class="relative z-10">
            <div class="w-12 h-12 rounded-full
              bg-cyan-100 dark:bg-cyan-500/10
              border border-cyan-300 dark:border-cyan-500/30
              flex items-center justify-center
              text-cyan-600 dark:text-cyan-400 text-xl mx-auto mb-4">
              @
            </div>
            <h3 class="text-gray-900 dark:text-white font-black uppercase tracking-tight text-xl mb-2">
              Join the Core
            </h3>
            <p class="text-[11px] text-gray-500 dark:text-slate-400 mb-6 leading-relaxed">
              Get dev deep-dives and project updates delivered weekly.
            </p>
            <div class="flex gap-2">
              <input
                type="email"
                placeholder="you@dev.os"
                class="bg-white dark:bg-black
                  border border-gray-200 dark:border-white/10
                  rounded px-3 py-2 flex-1 text-[10px] font-mono outline-none
                  focus:border-cyan-500 dark:focus:border-cyan-500
                  text-gray-900 dark:text-cyan-100
                  placeholder:text-gray-400 dark:placeholder:text-slate-600
                  transition-colors w-full"
              />
              <button class="bg-cyan-500 hover:bg-cyan-400 text-slate-900 font-bold px-4 py-2 text-[10px] uppercase tracking-wider rounded transition-colors whitespace-nowrap cursor-pointer">
                Execute
              </button>
            </div>
          </div>
        </div>

      </aside>
    </div>
  </section>
</BaseLayout>