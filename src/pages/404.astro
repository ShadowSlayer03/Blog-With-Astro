---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../lib/constants';
---

<BaseLayout title={`404 - ${SITE.title}`} description="The page you're looking for doesn't exist.">
  <section class="mx-auto flex max-w-4xl flex-col items-center justify-center px-4 py-32 text-center">
    <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-indigo-500">Error 404</p>
    <h1 class="mb-4 text-7xl font-black text-gray-900 dark:text-white">Page not found</h1>
    <p class="mb-8 max-w-md text-lg text-gray-600 dark:text-gray-400">
      Sorry, the page you're looking for doesn't exist or has been moved.
    </p>
    <div class="flex gap-4">
      <a
        href="/"
        class="rounded-lg bg-indigo-600 px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-indigo-700"
      >
        Go Home
      </a>
      <a
        href="/blog"
        class="rounded-lg border border-gray-300 px-6 py-3 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-800"
      >
        Browse Blog
      </a>
    </div>
  </section>
</BaseLayout>
