---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import Newsletter from '../components/Newsletter.astro';
import { SITE } from '../lib/constants';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title={`${SITE.title} - Modern Web Development Blog`}
  description={SITE.description}
>
  <!-- Hero Section -->
  <section class="noise-bg relative overflow-hidden">
    <!-- Gradient blobs -->
    <div class="pointer-events-none absolute -top-40 -right-40 h-96 w-96 rounded-full bg-indigo-400/10 blur-3xl dark:bg-indigo-600/10" aria-hidden="true"></div>
    <div class="pointer-events-none absolute -bottom-40 -left-40 h-96 w-96 rounded-full bg-purple-400/10 blur-3xl dark:bg-purple-600/10" aria-hidden="true"></div>

    <div class="relative mx-auto max-w-5xl px-6 pb-20 pt-24 sm:pb-28 sm:pt-32">
      <div class="mx-auto max-w-3xl text-center">
        <!-- Badge -->
        <div class="animate-fade-in-up mb-6 inline-flex items-center gap-2 rounded-full border border-indigo-200/60 bg-indigo-50/80 px-4 py-1.5 text-sm font-medium text-indigo-700 backdrop-blur-sm dark:border-indigo-500/20 dark:bg-indigo-500/10 dark:text-indigo-300">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-indigo-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-indigo-500"></span>
          </span>
          Exploring the modern web
        </div>

        <!-- Headline -->
        <h1 class="animate-fade-in-up stagger-1 text-balance text-4xl font-extrabold tracking-tight text-gray-900 dark:text-white sm:text-5xl lg:text-6xl">
          Ideas, code &
          <span class="relative whitespace-nowrap">
            <span class="relative bg-linear-to-r from-indigo-500 via-purple-500 to-pink-500 bg-clip-text text-transparent">
              craft
            </span>
          </span>
        </h1>

        <!-- Subline -->
        <p class="animate-fade-in-up stagger-2 mx-auto mt-6 max-w-xl text-lg leading-relaxed text-gray-500 dark:text-gray-400">
          A blog about web development, design systems, and building things that
          feel great. Fast by default, edge-deployed, zero-compromise.
        </p>

        <!-- CTAs -->
        <div class="animate-fade-in-up stagger-3 mt-10 flex flex-wrap items-center justify-center gap-4">
          <a
            href="/blog"
            class="group inline-flex items-center gap-2 rounded-xl bg-gray-900 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-gray-900/10 transition-all hover:bg-gray-800 hover:shadow-xl hover:shadow-gray-900/20 dark:bg-white dark:text-gray-900 dark:shadow-white/10 dark:hover:bg-gray-100"
          >
            Read the blog
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a
            href="/about"
            class="rounded-xl border border-gray-200 bg-white/80 px-6 py-3 text-sm font-semibold text-gray-700 backdrop-blur-sm transition-all hover:border-gray-300 hover:bg-white dark:border-white/10 dark:bg-white/5 dark:text-gray-300 dark:hover:border-white/20 dark:hover:bg-white/10"
          >
            About me
          </a>
        </div>

        <!-- Tech stack pills -->
        <div class="animate-fade-in-up stagger-4 mt-14 flex flex-wrap items-center justify-center gap-2">
          <span class="text-xs font-medium uppercase tracking-wider text-gray-400 dark:text-gray-600">Powered by</span>
          {['Astro 6', 'Tailwind v4', 'React 19', 'MDX', 'Cloudflare', 'Pagefind'].map(tech => (
            <span class="rounded-md border border-gray-150 bg-gray-50 px-2.5 py-1 text-xs font-medium text-gray-500 dark:border-white/5 dark:bg-white/5 dark:text-gray-500">
              {tech}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Posts -->
  {
    posts.length > 0 && (
      <section class="mx-auto max-w-5xl px-6 py-20">
        <div class="mb-10 flex items-end justify-between">
          <div>
            <p class="mb-1 text-sm font-semibold uppercase tracking-wider text-indigo-500">Latest</p>
            <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">Recent posts</h2>
          </div>
          <a
            href="/blog"
            class="group hidden items-center gap-1.5 text-sm font-medium text-gray-500 transition-colors hover:text-gray-900 dark:text-gray-400 dark:hover:text-white sm:inline-flex"
          >
            View all
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <BlogCard post={post} />
          ))}
        </div>
        <div class="mt-8 text-center sm:hidden">
          <a href="/blog" class="text-sm font-medium text-indigo-600 dark:text-indigo-400">
            View all posts &rarr;
          </a>
        </div>
      </section>
    )
  }

  <!-- Newsletter -->
  <section class="mx-auto max-w-5xl px-6 pb-24">
    <Newsletter />
  </section>
</BaseLayout>
