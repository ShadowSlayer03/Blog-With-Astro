---
import { SITE, NAV_LINKS } from '../lib/constants';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b backdrop-blur-xl
  border-gray-200/80 bg-white/85
  dark:border-white/5 dark:bg-[#020617]/85">

  <!-- Subtle top glow line in dark mode -->
  <div class="h-px w-full bg-gradient-to-r from-transparent via-cyan-500/20 to-transparent dark:via-cyan-500/30"></div>

  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3">

    <!-- Logo -->
    <a href="/" class="group flex items-center gap-2.5" aria-label={SITE.title}>
      <div class="flex h-8 w-8 items-center justify-center rounded-lg
        bg-cyan-500 shadow-sm shadow-cyan-500/25
        transition-shadow group-hover:shadow-md group-hover:shadow-cyan-500/40">
        <svg class="h-4 w-4 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
        </svg>
      </div>
      <span class="font-mono text-sm font-bold tracking-tight text-gray-900 dark:text-white">
        {SITE.title}<span class="text-cyan-500">_</span>
      </span>
    </a>

    <div class="flex items-center gap-1">

      <!-- Desktop nav -->
      <div class="hidden items-center sm:flex" id="desktop-nav">
        {NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              'relative rounded-lg px-3 py-2 text-xs font-mono uppercase tracking-widest transition-colors',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-cyan-600 dark:text-cyan-400'
                : 'text-gray-500 hover:text-gray-900 dark:text-slate-400 dark:hover:text-white',
            ]}
          >
            {link.label}
            {(currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))) && (
              <span class="absolute bottom-0 left-3 right-3 h-px bg-cyan-500" />
            )}
          </a>
        ))}
      </div>

      <div class="mx-2 hidden h-4 w-px bg-gray-200 dark:bg-white/10 sm:block" aria-hidden="true"></div>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        aria-label="Toggle dark mode"
        class="rounded-lg p-2 text-gray-500 transition-colors
          hover:bg-gray-100 hover:text-cyan-600
          dark:text-slate-400 dark:hover:bg-white/5 dark:hover:text-cyan-400"
      >
        <!-- Sun icon — shown in dark mode -->
        <svg class="hidden h-4 w-4 dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
        <!-- Moon icon — shown in light mode -->
        <svg class="block h-4 w-4 dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
      </button>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-toggle"
        class="rounded-lg p-2 text-gray-500 transition-colors
          hover:bg-gray-100 hover:text-gray-900
          dark:text-slate-400 dark:hover:bg-white/5 dark:hover:text-white sm:hidden"
        aria-label="Toggle menu"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile nav overlay -->
<div
  id="mobile-nav"
  class="hidden border-b
    border-gray-200 bg-white/95 backdrop-blur-xl
    dark:border-white/5 dark:bg-[#020617]/95 sm:hidden"
>
  <div class="mx-auto flex max-w-6xl flex-col gap-1 px-6 py-3">
    {NAV_LINKS.map((link) => (
      <a
        href={link.href}
        class:list={[
          'rounded-lg px-3 py-2.5 text-sm font-mono uppercase tracking-widest transition-colors',
          currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
            ? 'bg-cyan-500/10 text-cyan-600 dark:text-cyan-400'
            : 'text-gray-500 hover:bg-gray-100 dark:text-slate-400 dark:hover:bg-white/5',
        ]}
      >
        {link.label}
      </a>
    ))}
  </div>
</div>

<script>
  // Restore theme on load before paint (prevents flash)
  const saved = localStorage.getItem('theme');
  const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  if (saved === 'dark' || (!saved && prefersDark)) {
    document.documentElement.classList.add('dark');
  } else {
    document.documentElement.classList.remove('dark');
  }

  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  document.getElementById('mobile-menu-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-nav')?.classList.toggle('hidden');
  });
</script>