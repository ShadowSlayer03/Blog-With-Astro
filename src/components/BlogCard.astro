---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, heroImage, tags } = post.data;

const formattedDate = new Date(pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group glow">
  <a href={`/blog/${post.id}`} class="block overflow-hidden rounded-2xl border border-gray-100 bg-white transition-all duration-300 hover:border-gray-200 hover:shadow-lg hover:shadow-gray-200/50 dark:border-white/5 dark:bg-gray-900 dark:hover:border-white/10 dark:hover:shadow-none">
    {
      heroImage ? (
        <div class="overflow-hidden">
          <img
            src={heroImage}
            alt={title}
            class="aspect-16/10 w-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
        </div>
      ) : (
        <div class="flex aspect-16/10 items-center justify-center bg-linear-to-br from-indigo-50 via-purple-50 to-pink-50 dark:from-indigo-950/40 dark:via-purple-950/40 dark:to-pink-950/40">
          <svg class="h-12 w-12 text-indigo-300 dark:text-indigo-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
        </div>
      )
    }

    <div class="flex flex-col gap-3 p-5">
      <div class="flex items-center gap-2 text-xs">
        <time datetime={pubDate.toISOString()} class="text-gray-400 dark:text-gray-500">
          {formattedDate}
        </time>
        {
          tags && tags.length > 0 && (
            <>
              <span class="text-gray-300 dark:text-gray-700">&middot;</span>
              <span class="truncate font-medium text-indigo-500 dark:text-indigo-400">{tags[0]}</span>
            </>
          )
        }
      </div>

      <h3 class="text-balance text-lg font-semibold leading-snug text-gray-900 transition-colors group-hover:text-indigo-600 dark:text-white dark:group-hover:text-indigo-400">
        {title}
      </h3>

      <p class="line-clamp-2 text-sm leading-relaxed text-gray-500 dark:text-gray-400">
        {description}
      </p>

      <div class="mt-1 flex items-center gap-1.5 text-sm font-medium text-indigo-600 dark:text-indigo-400">
        <span>Read more</span>
        <svg class="h-3.5 w-3.5 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </div>
    </div>
  </a>
</article>
