---
interface Props {
  tag: string;
  size?: 'sm' | 'md';
}

const { tag, size = 'sm' } = Astro.props;

const sizeClasses = {
  sm: 'px-2.5 py-0.5 text-[11px]',
  md: 'px-3 py-1 text-xs',
};
---

<a
  href={`/blog/tag/${tag}`}
  class:list={[
    'inline-block rounded-md font-mono uppercase tracking-wider font-medium transition-all hover:-translate-y-px',
    'border border-cyan-200/60 bg-cyan-50 text-cyan-700',
    'hover:border-cyan-300 hover:bg-cyan-100',
    'dark:border-cyan-500/20 dark:bg-cyan-500/10 dark:text-cyan-400',
    'dark:hover:border-cyan-500/30 dark:hover:bg-cyan-500/15',
    sizeClasses[size],
  ]}
>
  {tag}
</a>
