---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  article?: boolean;
  isBlogPost?: boolean;
}

const { title, description, image, article, isBlogPost=false } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <SEOHead title={title} description={description} image={image} article={article} />
  </head>
  <body class="flex min-h-screen flex-col" {...(!isBlogPost ? { 'data-pagefind-ignore': 'all' } : {})}>
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
