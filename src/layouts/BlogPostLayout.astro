---
import BaseLayout from './BaseLayout.astro';
import TagPill from '../components/TagPill.astro';
import Newsletter from '../components/Newsletter.astro';
import type { CollectionEntry } from 'astro:content';

import ScrollProgress from '../components/islands/ScrollProgress';
import TableOfContents from '../components/islands/TableOfContents';
import LikeButton from '../components/islands/LikeButton';
import ShareButton from '../components/islands/ShareButton';
import GiscusComments from '../components/islands/GiscusComments';
import BackToTop from '../components/islands/BackToTop';

type Props = CollectionEntry<'blog'>['data'] & {
  slug: string;
  rawContent?: string;
};

const { title, description, pubDate, updatedDate, heroImage, tags, slug, rawContent } = Astro.props;

const formattedPubDate = new Date(pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate
  ? new Date(updatedDate).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const wordCount = rawContent ? rawContent.trim().split(/\s+/).length : 0;
const readingMinutes = Math.max(1, Math.ceil(wordCount / 200));

const currentUrl = new URL(Astro.url.pathname, Astro.site).toString();

const ogImage = heroImage || `/og/${slug}.png`;
---

<BaseLayout title={title} description={description} image={ogImage} article={true} isBlogPost={true}>
  <ScrollProgress client:idle />

  <TableOfContents client:idle />

  <article class="mx-auto max-w-3xl px-6 pb-16 pt-12">
    <a
      href="/blog"
      class="group mb-8 inline-flex items-center gap-1.5 text-sm font-medium text-gray-400 transition-colors hover:text-gray-900 dark:text-gray-600 dark:hover:text-white"
    >
      <svg class="h-4 w-4 transition-transform group-hover:-translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      All posts
    </a>

    <header class="mb-10">
      {tags && tags.length > 0 && (
        <div class="mb-4 flex flex-wrap items-center gap-2">
          {tags.map((tag) => <TagPill tag={tag} size="sm" />)}
        </div>
      )}

      <h1 class="text-balance text-3xl font-extrabold tracking-tight text-gray-900 dark:text-white sm:text-4xl lg:text-5xl">
        {title}
      </h1>

      <p class="mt-4 text-lg leading-relaxed text-gray-500 dark:text-gray-400">{description}</p>

      <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 border-b border-gray-100 pb-6 text-sm text-gray-400 dark:border-white/5 dark:text-gray-500">
        <time datetime={pubDate.toISOString()} class="font-medium">
          {formattedPubDate}
        </time>
        {
          formattedUpdatedDate && (
            <span class="flex items-center gap-1">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182" />
              </svg>
              Updated {formattedUpdatedDate}
            </span>
          )
        }
        {wordCount > 0 && (
          <span class="flex items-center gap-1">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {readingMinutes} min read
          </span>
        )}
      </div>
    </header>

    {
      heroImage && (
        <img
          src={heroImage}
          alt={title}
          class="mb-10 aspect-video w-full rounded-2xl object-cover shadow-lg shadow-gray-200/50 dark:shadow-none"
          loading="eager"
        />
      )
    }

    <div class="prose prose-lg prose-gray max-w-none dark:prose-invert prose-headings:scroll-mt-20 prose-headings:font-bold prose-headings:tracking-tight prose-a:font-medium prose-a:text-indigo-600 prose-a:no-underline hover:prose-a:text-indigo-500 prose-a:transition-colors prose-img:rounded-xl prose-pre:border prose-pre:border-gray-200 dark:prose-pre:border-gray-800 dark:prose-a:text-indigo-400">
      <slot />
    </div>

    <div class="mt-12 flex flex-wrap items-center gap-3 border-t border-gray-100 pt-8 dark:border-white/5">
      <LikeButton client:visible slug={slug} />
      <ShareButton client:visible title={title} url={currentUrl} />
    </div>

    <div class="mt-12">
      <Newsletter />
    </div>

    <GiscusComments client:visible />
  </article>

  <BackToTop client:idle />
</BaseLayout>
